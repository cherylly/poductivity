# Content Digest

ANTHROPIC_AUTH_TOKEN=your_token_here
LLM_BASE_URL=https://ai-coding-ali.deeproute.cn/v1
LLM_MODEL=glm-5.1

# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
RECIPIENT_EMAIL=your_email@gmail.com

# Web
WEB_BASE_URL=http://localhost:8080
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Podcast Index (optional, for searching podcast RSS)
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=

# Schedule (cron expression for daily digest)
DIGEST_CRON_HOUR=2
DIGEST_CRON_MINUTE=0
EMAIL_SEND_HOUR=7
EMAIL_SEND_MINUTE=0

# ASR (optional, for podcast transcription)
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
